#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix-transform = &default_transform;
        zmk,physical-layout = &physical_layout0;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <16>;
        rows = <6>;
        map = 
RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)                                                     RC(0,10) RC(0,11) RC(0,12) RC(0,13) RC(0,14) RC(0,15)
RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)                                                     RC(1,10) RC(1,11) RC(1,12) RC(1,13) RC(1,14) RC(1,15)
RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)                                                     RC(2,10) RC(2,11) RC(2,12) RC(2,13) RC(2,14) RC(2,15)
RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)         RC(3,6) RC(3,7)     RC(3,8) RC(3,9)         RC(3,10) RC(3,11) RC(3,12) RC(3,13) RC(3,14) RC(3,15)
        RC(4,1) RC(4,2) RC(4,3) RC(4,4)         RC(4,5) RC(4,6) RC(4,7)     RC(4,8) RC(4,9) RC(4,10)         RC(4,11) RC(4,12) RC(4,13) RC(4,14)
                                                                RC(5,7)     RC(5,8)
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "col2row";
        wakeup-source;

        row-gpios
            = <&pro_micro 21 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&pro_micro 20 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&pro_micro 19 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&pro_micro 18 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&pro_micro 15 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&pro_micro 2 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            ;
    };

    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "Default";
        transform = <&default_transform>;
        kscan = <&kscan0>;

        keys  //                     w   h     x    y   r  rx  ry
            = <&key_physical_attrs 100 100     0   24   0   0   0>
            , <&key_physical_attrs 100 100   100   14   0   0   0>
            , <&key_physical_attrs 100 100   200    5   0   0   0>
            , <&key_physical_attrs 100 100   300    0   0   0   0>
            , <&key_physical_attrs 100 100   400   10   0   0   0>
            , <&key_physical_attrs 100 100   500   24   0   0   0>
            , <&key_physical_attrs 100 100   875   24   0   0   0>
            , <&key_physical_attrs 100 100   975   10   0   0   0>
            , <&key_physical_attrs 100 100  1075    0   0   0   0>
            , <&key_physical_attrs 100 100  1175    5   0   0   0>
            , <&key_physical_attrs 100 100  1275   14   0   0   0>
            , <&key_physical_attrs 100 100  1375   24   0   0   0>
            , <&key_physical_attrs 100 100     0  124   0   0   0>
            , <&key_physical_attrs 100 100   100  114   0   0   0>
            , <&key_physical_attrs 100 100   200  105   0   0   0>
            , <&key_physical_attrs 100 100   300  100   0   0   0>
            , <&key_physical_attrs 100 100   400  110   0   0   0>
            , <&key_physical_attrs 100 100   500  124   0   0   0>
            , <&key_physical_attrs 100 100   875  124   0   0   0>
            , <&key_physical_attrs 100 100   975  110   0   0   0>
            , <&key_physical_attrs 100 100  1075  100   0   0   0>
            , <&key_physical_attrs 100 100  1175  105   0   0   0>
            , <&key_physical_attrs 100 100  1275  114   0   0   0>
            , <&key_physical_attrs 100 100  1375  124   0   0   0>
            , <&key_physical_attrs 100 100     0  224   0   0   0>
            , <&key_physical_attrs 100 100   100  214   0   0   0>
            , <&key_physical_attrs 100 100   200  205   0   0   0>
            , <&key_physical_attrs 100 100   300  200   0   0   0>
            , <&key_physical_attrs 100 100   400  210   0   0   0>
            , <&key_physical_attrs 100 100   500  224   0   0   0>
            , <&key_physical_attrs 100 100   875  224   0   0   0>
            , <&key_physical_attrs 100 100   975  210   0   0   0>
            , <&key_physical_attrs 100 100  1075  200   0   0   0>
            , <&key_physical_attrs 100 100  1175  205   0   0   0>
            , <&key_physical_attrs 100 100  1275  214   0   0   0>
            , <&key_physical_attrs 100 100  1375  224   0   0   0>
            , <&key_physical_attrs 100 100     0  324   0   0   0>
            , <&key_physical_attrs 100 100   100  314   0   0   0>
            , <&key_physical_attrs 100 100   200  305   0   0   0>
            , <&key_physical_attrs 100 100   300  300   0   0   0>
            , <&key_physical_attrs 100 100   400  310   0   0   0>
            , <&key_physical_attrs 100 100   500  324   0   0   0>
            , <&key_physical_attrs 100 100   575  340   0   0   0>
            , <&key_physical_attrs 100 100   650  360   0   0   0>
            , <&key_physical_attrs 100 100   725  360   0   0   0>
            , <&key_physical_attrs 100 100   800  340   0   0   0>
            , <&key_physical_attrs 100 100   875  324   0   0   0>
            , <&key_physical_attrs 100 100   975  310   0   0   0>
            , <&key_physical_attrs 100 100  1075  300   0   0   0>
            , <&key_physical_attrs 100 100  1175  305   0   0   0>
            , <&key_physical_attrs 100 100  1275  314   0   0   0>
            , <&key_physical_attrs 100 100  1375  324   0   0   0>
            , <&key_physical_attrs 100 100   100  414   0   0   0>
            , <&key_physical_attrs 100 100   200  405   0   0   0>
            , <&key_physical_attrs 100 100   300  400   0   0   0>
            , <&key_physical_attrs 100 100   400  410   0   0   0>
            , <&key_physical_attrs 100 100   500  440   0   0   0>
            , <&key_physical_attrs 100 100   575  460   0   0   0>
            , <&key_physical_attrs 100 100   650  475   0   0   0>
            , <&key_physical_attrs 100 100   725  475   0   0   0>
            , <&key_physical_attrs 100 100   800  460   0   0   0>
            , <&key_physical_attrs 100 100   875  440   0   0   0>
            , <&key_physical_attrs 100 100   975  410   0   0   0>
            , <&key_physical_attrs 100 100  1075  400   0   0   0>
            , <&key_physical_attrs 100 100  1175  405   0   0   0>
            , <&key_physical_attrs 100 100  1275  414   0   0   0>
