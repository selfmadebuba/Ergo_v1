        , <&key_physical_attrs 100 100   725  475   0   0   0>  // RC(4,8)
        , <&key_physical_attrs 100 100   800  460   0   0   0>  // RC(4,9)
        , <&key_physical_attrs 100 100   875  440   0   0   0>  // RC(4,10)
        , <&key_physical_attrs 100 100   975  410   0   0   0>  // RC(4,11)
